{
  "expo": {
    "name": "trendingpolls",
    "slug": "trendingpolls",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trendingpolls.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#5b21b6"
      },
      "package": "com.trendingpolls.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-status-bar", "expo-web-browser", "expo-font", "expo-asset"],
    "scheme": "trendingpolls",
    "experiments": {
      "typedRoutes": true
    }
  }
}
